# =============================================================================
# Frontend-Konfiguration (Vite)
# =============================================================================
# Diese Variablen werden im Browser eingebettet — KEINE Geheimnisse hier!

# Mock-Modus: true = lokales In-Memory-Backend, false = echtes HTTP-Backend
VITE_USE_MOCK=true

# Basis-URL des echten Backends (nur relevant wenn VITE_USE_MOCK=false)
# Beispiel: https://api.my-cleancenter.de
VITE_API_BASE_URL=
